FROM python:3.11-slim

WORKDIR /app

COPY requirements-api.txt .
RUN pip install --no-cache-dir -r requirements-api.txt

COPY scraper/ ./scraper/
COPY pipeline/ ./pipeline/
COPY rag/ ./rag/
COPY .env .env

ENV PYTHONPATH=/app

EXPOSE 8000
CMD ["uvicorn", "rag.api:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
